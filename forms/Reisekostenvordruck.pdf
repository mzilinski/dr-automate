if\( \(event.change!=""\) && \(true==event.rc\) \) {
  var strGB=new String\("ABCDEFGHIJKLMNOPQRSTUVWXYZÄÖÜ"\);
   var strKB=new String\("abcdefghijklmnopqrstuvwxyzäöü"\); // Reihenfolge synchron zu <strGB>

   if\(-1 != strKB.indexOf\(event.change\)\)
   {       for\(var i=0;i<strKB.length;i++\)
           {       if\(event.change==strKB.substring\(i,i+1\)\)
                   {       event.change=strGB.substring\(i,i+1\);
                   }
           }
   }
   if\(-1 == strGB.indexOf\(event.change\)\)
   {       app.beep\(0\);event.rc=false;
   }
}) >>
 >>
>>
