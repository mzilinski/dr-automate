/JS (function SYS_CHECK_MF_FIELDS\(\)\r{\r        var n = this.numFields;\r        var f;\r        var fn;\r        for\(var i=0;i<n;i++\)\r        {\r                fn = this.getNthFieldName\(i\);\r                if\( \(""!=fn\) && \("SYSTEM_P1_DUMMY"!=fn\) \)\r                {\r                        f = this.getField\(fn\);\r                        if\( \(null!=f\) && \("button"!=f.type\) \)\r                        {\r                                if\(\(f.required\)&&\(""==f.value\)\)\r                                {\r                                        return false;\r                                }\r                        }\r                }\r        }\r    	if\(true==SYS_CB_HDL_OBJ21\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ22\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ23\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ24\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ25\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ26\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ27\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ28\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ29\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ30\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ32\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ33\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ34\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ35\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ36\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ37\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ38\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ39\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ40\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ41\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ42\(false\)\){return false;}\r    	if\(true==SYS_CB_HDL_OBJ43\(false\)\){return false;}\r    	if\(true==SYS_