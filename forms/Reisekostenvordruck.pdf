/JS (function SYS_RESET_BG_COLORS_UPON_ALL_PAGES\(\)\r{\rSYS_PA2_SUBMIT\(\);\r        var n = this.numFields;\r        var f;\r        var fn;\r        for\(var i=0;i<n;i++\)\r        {\r                fn = this.getNthFieldName\(i\);\r                if\( \(""!=fn\) && \("SYSTEM_P1_DUMMY"!=fn\) \)\r                {\r                        f = this.getField\(fn\);\r                        if\( \(null!=f\) && \("button"!=f.type\) \)\r                        {\r                                if\("checkbox"==f.type\)\r                                { \r                                  f.style=style.cr;\r                                }\r                                if\(f.readonly\)\r                                {\r                                        if\(f.readonly\) SYS_FILL\(f,["RGB",0.749,0.749,0.749]\);\r                                }\r                                else\r                                {\r                                     SYS_FILL\(f,getBgColor\(fn\)\);\r                                }\r                                if\(\(f.required\)&&\(""==f.value\)\)\r                                {\r                                        f.strokeColor=color.red;\r                                }\r                                else\r                                {\r                                   f.strokeColor=getBorderColor\(fn\);\r                                }\r                        }\r                }\r        }\r    	SYS_CB_HDL_OBJ21\(true\);\r    	SYS_CB_HDL_OBJ22\(true\);\r    	SYS_CB_HDL_OBJ23\(true\);\r    	SYS_CB_HDL_OBJ24\(true\);\r    	SYS_CB_HDL_OBJ25\(true\);\r    	SYS_CB_HDL_OBJ26\(true\);\r    	SYS_CB_HDL_OBJ27\(true\);\r    	SYS_CB_HDL_OBJ28\(true\);\r    	SYS_CB_HDL_OBJ29\(true\);\r    	SYS_CB_HDL_OBJ30\(true\);\r    	SYS_CB_HDL_OBJ32\(true\);\r    	SYS_CB_HDL_OBJ33\(true\);\r    	SYS_CB_HDL_OBJ34\(true\);\r    	SYS_CB_HDL_OBJ35\(true\);\r    	SYS_CB_HDL_OBJ36\(true\);\r    	SYS_CB_HDL_OBJ37\(true\);\