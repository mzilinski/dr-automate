/JS (function SYS_RESET_BG_COLORS_UPON_ALL_PAGES\(\)\r{\rSYS_PA2_SUBMIT\(\);\r        var n = this.numFields;\r        var f;\r        var fn;\r        for\(var i=0;i<n;i++\)\r        {\r                fn = this.getNthFieldName\(i\);\r                if\( \(""!=fn\) && \("SYSTEM_P1_DUMMY"!=fn\) \)\r                {\r                        f = this.getField\(fn\);\r                        if\( \(null!=f\) && \("button"!=f.type\) \)\r                        {\r                                if\("checkbox"==f.type\)\r                                { \r                                  f.style=style.cr;\r                                }\r                                if\(f.readonly\)\r                                {\r                                        if\(f.readonly\) SYS_FILL\(f,["RGB",0.749,0.749,0.749]\);\r                                }\r                                else\r                                {\r                                     SYS_FILL\(f,getBgColor\(fn\)\);\r                                }\r                                if\(\(f.required\)&&\(""==f.value\)\)\r                                {\r                                        f.strokeColor=color.red;\r                                }\r                                else\r                                {\r                                   f.strokeColor=getBorderColor\(fn\);\r                                }\r                        }\r                }\r        }\r    	SYS_CB_HDL_Fruehstueck\(true\);\r    	SYS_CB_HDL_Mittag\(true\);\r    	SYS_CB_HDL_Abend\(true\);\r    	SYS_CB_HDL_Fruehstueck1\(true\);\r    	SYS_CB_HDL_Mittag1\(true\);\r    	SYS_CB_HDL_Abend1\(true\);\r    	SYS_CB_HDL_Fruehstueck2\(true\);\r    	SYS_CB_HDL_Mittag2\(true\);\r    	SYS_CB_HDL_Abend2\(true\);\r    	SYS_CB_HDL_Fruehstueck3\(true\);\r    	SYS_CB_HDL_Mittag3\(true\);\r    	SYS_CB_HDL_Abend3\(true\);\r    	SYS_CB_HDL_Fruehstueck4\(true\);\r    	SYS_CB_HDL_Mittag4\(true\);\r    	SYS_CB_HDL_Abend4\(true\);\r    	SYS_CB_HDL_Fruehstueck5\(true\);\r    	SYS_CB_HDL_Mittag5\(true\);\r    	SYS_CB_HDL_Abend5\(true\);\r    	SYS_CB_HDL_Fruehstueck6\(true\);\r    	SYS_CB_HDL_Mittag6\(true\);\r    	SYS_CB_HDL_Abend6\(true\);\r    	SYS_CB_HDL_Fruehstueck7\(true\);\r    	SYS_CB_HDL_Mittag7\(true\);\r    	SYS_CB_HDL_Abend7\(true\);\r    	SYS_CB_HDL_Fruehstueck8\(true\);\r    	SYS_CB_HDL_Mittag8\(true\);\r    	SYS_CB_HDL_Abend8\(true\);\r    	SYS_CB_HDL_Abend9\(true\);\r    	SYS_CB_HDL_Abend10\(true\);\r    	SYS_CB_HDL_Fruehstueck9\(true\);\r    	SYS_CB_HDL_Mittag9\(true\);\r    	SYS_CB_HDL_Abend11\(true\);\r    	SYS_CB_HDL_Fruehstueck10\(true\);\r    	SYS_CB_HDL_Mittag10\(true\);\r    	SYS_CB_HDL_Abend12\(true\);\r    	SYS_CB_HDL_Fruehstueck11\(true\);\r    	SYS_CB_HDL_Mittag11\(true\);\r    	SYS_CB_HDL_Abend13\(true\);\r    	SYS_CB_HDL_Fruehstueck12\(true\);\r    	SYS_CB_HDL_Mittag12\(true\);\r    	SYS_CB_HDL_Abend14\(true\);\r    	SYS_CB_HDL_Fruehstueck13\(true\);\r    	SYS_CB_HDL_Mittag13\(true\);\r    	SYS_CB_HDL_Abend15\(true\);\r    	SYS_CB_HDL_Fruehstueck14\(true\);\r    	SYS_CB_HDL_Mittag14\(true\);\r    	SYS_CB_HDL_Abend16\(true\);\r    	SYS_CB_HDL_Fruehstueck15\(true\);\r    	SYS_CB_HDL_Mittag15\(true\);\r    	SYS_CB_HDL_Abend18\(true\);\r    	SYS_CB_HDL_Fruehstueck16\(true\);\r    	SYS_CB_HDL_Mittag16\(true\);\r    	SYS_CB_HDL_Abend19\(true\);\r    	SYS_CB_HDL_Fruehstueck17\(true\);\r    	SYS_CB_HDL_Mittag17\(true\);\r    	SYS_CB_HDL_Abend20\(true\);\r    	SYS_CB_HDL_Abend17\(true\);\r    	SYS_CB_HDL_Abend21\(true\);\r}\r)
